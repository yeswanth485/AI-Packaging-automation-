# Application
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database
# Connection pooling is configured via URL parameters:
# - connection_limit: max number of connections in pool (default: num_cpus * 2 + 1)
# - pool_timeout: seconds to wait for connection (default: 10)
# - connect_timeout: seconds to wait for initial connection (default: 5)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/packaging_optimizer?schema=public&connection_limit=10&pool_timeout=10&connect_timeout=5

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# API Keys
API_KEY_ROTATION_DAYS=90

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads

# Packing Configuration
DEFAULT_BUFFER_PADDING=2
DEFAULT_VOLUMETRIC_DIVISOR=5000
DEFAULT_SHIPPING_RATE_PER_KG=0.5

# Simulation
SIMULATION_TIMEOUT_MS=300000
MAX_CONCURRENT_SIMULATIONS=5

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-change-in-production

# Monitoring
LOG_LEVEL=info
SENTRY_DSN=

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@packingoptimizer.com
