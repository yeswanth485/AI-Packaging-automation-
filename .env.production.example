# Production Environment Variables for Railway Deployment
# Copy this file and set the actual values in Railway dashboard

# Application
NODE_ENV=production
PORT=3000
API_VERSION=v1

# Database (automatically set by Railway PostgreSQL service)
# DATABASE_URL=postgresql://user:password@host:port/database

# Redis (automatically set by Railway Redis service)
# REDIS_URL=rediss://default:password@host:port

# JWT Configuration (REQUIRED - generate secure secrets)
JWT_SECRET=your-super-secure-jwt-secret-key-for-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Session Configuration (REQUIRED - generate secure secret)
SESSION_SECRET=your-super-secure-session-secret-for-production

# API Configuration
API_KEY_ROTATION_DAYS=90

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE_MB=50

# Packing Configuration
DEFAULT_BUFFER_PADDING=2
DEFAULT_VOLUMETRIC_DIVISOR=5000
DEFAULT_SHIPPING_RATE_PER_KG=0.5

# Simulation
SIMULATION_TIMEOUT_MS=300000
MAX_CONCURRENT_SIMULATIONS=5

# Security
BCRYPT_ROUNDS=12

# Monitoring
LOG_LEVEL=info

# CORS (set to your frontend domain)
ALLOWED_ORIGINS=https://your-domain.com

# Optional: Email configuration
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=noreply@your-domain.com

# Optional: Monitoring
# SENTRY_DSN=